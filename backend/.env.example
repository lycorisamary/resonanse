# Настройки приложения
DEBUG=True

# Настройки базы данных PostgreSQL
POSTGRES_USER=resonans_user
POSTGRES_PASSWORD=resonans_password
POSTGRES_DB=resonans_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Настройки Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Секретный ключ для JWT (сгенерируйте свой случайный ключ)
# Можно сгенерировать командой: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS настройки (для Flutter приложения)
CORS_ORIGINS=["*"]
